# ==================================================
# GeoAI Flood Risk Agent
# Git Ignore Configuration
# --------------------------------------------------
# This repository tracks only reproducible project
# artifacts (code, documentation, configuration).
# Raw datasets, processed datasets, outputs, and
# local development files are intentionally excluded.
# ==================================================

# ==================================================
# Virtual Environment
# ==================================================

.venv/

# ==================================================
# Python
# ==================================================

__pycache__/
*.py[cod]
*$py.class

# ==================================================
# Jupyter Notebook Checkpoints
# ==================================================

.ipynb_checkpoints/

# ==================================================
# Environment Variables
# ==================================================

.env
.env.*

# ==================================================
# VS Code
# ==================================================

.vscode/

# ==================================================
# Operating System Files
# ==================================================

.DS_Store
Thumbs.db
desktop.ini

# ==================================================
# Project Data (NOT TRACKED)
# --------------------------------------------------
# GitHub does NOT store datasets.
# Anyone reproducing the project should obtain the
# datasets by following docs/datasets.md.
# ==================================================

data/raw/
data/processed/
data/outputs/

# ==================================================
# Temporary Files
# ==================================================

*.tmp
*.temp
*.bak
*.log

# ==================================================
# GIS Temporary Files
# ==================================================

*.aux
*.aux.xml
*.ovr
*.qml~
*.qmd~
*.lock

# ==================================================
# Python Build Artifacts
# ==================================================

build/
dist/
*.egg-info/

# ==================================================
# Coverage & Testing
# ==================================================

.coverage
.pytest_cache/
htmlcov/

# ==================================================
# IDE Files
# ==================================================

.idea/

# ==================================================
# Local Secrets
# ==================================================

secrets/
credentials/